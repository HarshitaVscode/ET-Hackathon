# =============================================================================
# Vayu-Drishti Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Local development runs without Docker, Kafka, or external databases.
# The app uses SQLite, an in-memory event bus, and lightweight local storage.
# =============================================================================

# --- Application ---
APP_NAME=vayu-drishti
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production
APP_LOG_LEVEL=INFO
APP_PORT=8000

# --- APIs (leave blank to skip polling, values are optional for local dev) ---
CPCB_API_BASE=https://app.cpcbccr.com/api
CPCB_API_KEY=
CPCB_POLL_INTERVAL_SECONDS=900

IMD_API_BASE=https://mausam.imd.gov.in/api
IMD_API_KEY=
IMD_POLL_INTERVAL_HOURS=1

GOOGLE_MAPS_API_KEY=
GOOGLE_TRAFFIC_POLL_INTERVAL_SECONDS=300

SENTINEL_CLIENT_ID=
SENTINEL_CLIENT_SECRET=
SENTINEL_COLLECTION=sentinel-2-l2a

BHUVAN_API_KEY=
BHUVAN_API_BASE=https://bhuvan.nrsc.gov.in/api

# --- LLM (local Ollama / vLLM endpoint) ---
LLM_MODEL=llama3-70b
LLM_ENDPOINT=http://localhost:8001/v1
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1
LLM_CONTEXT_WINDOW=8192

# --- Agent Config ---
AGENT_FORECAST_HORIZON_HOURS=72
AGENT_GRID_RESOLUTION_METERS=50
AGENT_CONFIDENCE_THRESHOLD=0.7
AGENT_CACHE_TTL_SECONDS=300
AGENT_MAX_RETRIES=3
AGENT_TIMEOUT_SECONDS=30

# --- RL / Decision Engine ---
RL_TRAFFIC_LEARNING_RATE=0.0003
RL_TRAFFIC_GAMMA=0.99
RL_SQUAD_LEARNING_RATE=0.001
RL_EMERGENCY_ALPHA=0.5

# --- Feature Store ---
FEATURE_STORE_ONLINE=local
FEATURE_STORE_OFFLINE=sqlite
FEATURE_TTL_DAYS=90

# --- Alerting (leave blank to disable) ---
ALERT_EMAIL_SMTP=smtp.gmail.com
ALERT_EMAIL_PORT=587
ALERT_EMAIL_USER=
ALERT_EMAIL_PASSWORD=
ALERT_SLACK_WEBHOOK=
ALERT_PAGERDUTY_KEY=

# --- Geo Bounds (Default: Delhi) ---
CITY_LAT_MIN=28.40
CITY_LAT_MAX=28.88
CITY_LON_MIN=76.84
CITY_LON_MAX=77.34
CITY_GRID_SIZE_X=800
CITY_GRID_SIZE_Y=960

# --- Paths ---
DATA_DIR=./backend/data
MODEL_DIR=./backend/models_data
TEMP_DIR=./tmp
