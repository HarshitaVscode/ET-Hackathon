{
  "title": "Vayu-Drishti Overview",
  "uid": "vayu-overview",
  "version": 1,
  "panels": [
    {
      "title": "City Average AQI",
      "type": "graph",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "avg(aqi_forecast)", "legendFormat": "Forecast"}]
    },
    {
      "title": "Source Attribution",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "source_contribution_percent"}]
    },
    {
      "title": "Service Health",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "up"}]
    }
  ]
}
