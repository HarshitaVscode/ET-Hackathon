root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{yml,yaml}]
indent_size = 2

[*.{json,md}]
indent_size = 2

[{Makefile,makefile}]
indent_style = tab

[*.bat]
end_of_line = crlf

[*.{py,pyw}]
indent_size = 4

[*.{ts,tsx,js,jsx,css,scss}]
indent_size = 2
